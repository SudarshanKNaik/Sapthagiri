# Optional: Twilio SMS
# 1) Copy this file to `backend/.env`
# 2) Fill in values from Twilio Console
# Notes:
# - Phone numbers should be E.164 format, e.g. +16414066203
# - Keep `.env` private (it is gitignored in backend/.gitignore)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Gemini API key (optional, for chat assistant)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Backend port
PORT=3002
